# Copy this file to .env.local and fill in your real values
# NEVER commit .env.local to git

# Set to false once Supabase is connected
NEXT_PUBLIC_DEMO_MODE=false

# From your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Your app URL (localhost for dev, Vercel URL for production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Company details shown in the UI and PDF reports
NEXT_PUBLIC_COMPANY_NAME=Taylor Engineering Agencies Limited
NEXT_PUBLIC_COMPANY_EMAIL=info@tayeng.com
NEXT_PUBLIC_COMPANY_PHONE=+61 7 0000 0000
NEXT_PUBLIC_COMPANY_ADDRESS=Brisbane, QLD, Australia
