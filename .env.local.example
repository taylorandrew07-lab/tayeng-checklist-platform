# Copy this file to .env.local and fill in your real values
# NEVER commit .env.local to git

# ── Supabase (from Settings > API in your Supabase project) ─────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── App URL ──────────────────────────────────────────────────────────────────
# Set to your Vercel deployment URL in production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Email notifications (optional but recommended) ───────────────────────────
# Get a free API key at https://resend.com — verify your sending domain there too.
# If not set, admin notification emails are silently skipped.
RESEND_API_KEY=re_your_api_key_here

# ── Cron (document expiry reminders) ─────────────────────────────────────────
# Secret that protects /api/cron/document-reminders. Vercel Cron sends it as
# `Authorization: Bearer <CRON_SECRET>`. Set the SAME value in the Vercel project
# (Settings → Environment Variables). Generate one, e.g.: openssl rand -hex 32
CRON_SECRET=your-long-random-secret-here

# ── Scripts only (not needed at runtime) ─────────────────────────────────────
# Used by scripts/*.mjs for one-time database operations.
# Never used by the app server itself.
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_ACCESS_TOKEN=your-supabase-access-token
ADMIN_EMAIL=your-admin@example.com
ADMIN_PASSWORD=change-me-immediately
ADMIN_FULL_NAME=Your Name
TARGET_EMAIL=user-to-fix@example.com
TARGET_ROLE=surveyor
